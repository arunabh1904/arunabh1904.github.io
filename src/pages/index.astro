---
import HomeLayout from '../layouts/HomeLayout.astro';
import Icon from '../components/Icon.astro';
import { getPostsBySection } from '../lib/content';
import { codePracticeProblems } from '../lib/code-practice';
import { READING_LIST_ITEMS } from '../lib/reading-list';
import { CONTACT_LINKS } from '../lib/site';

const paperPosts = await getPostsBySection('paper-shorts', 'desc');
const revisionPosts = (await getPostsBySection('revision-notes', 'desc')).filter(
  (post) => post.data.postSlug !== 'cs336-revision-notes',
);
const blogPosts = await getPostsBySection('blog', 'desc');

const sectionCards = [
  {
    href: '/paper_summaries_field.html',
    title: 'Arxiv Notes',
    description: 'Notes on interesting papers I want to remember.',
    count: paperPosts.length,
  },
  {
    href: '/blog.html',
    title: 'Blog',
    description: 'Long-form explanations and deep technical surveys.',
    count: blogPosts.length,
  },
  {
    href: '/revision_notes.html',
    title: 'Revision Notes',
    description: 'Lecture notes rebuilt for recall and reuse.',
    count: revisionPosts.length,
  },
  {
    href: '/reading_list.html',
    title: 'Reading List',
    description: 'Interesting writing worth returning to.',
    count: READING_LIST_ITEMS.length,
  },
  {
    href: '/code.html',
    title: 'Code',
    description: 'Coding practice for core ML and vision ideas.',
    count: codePracticeProblems.length,
  },
] as const;

const timelineEntries = [
  {
    years: '2010–2014',
    title: 'MIT, Manipal',
    summary:
      'Mechatronics projects made robotics real. For my thesis, our team built an areca-nut harvesting robot meant to make a dangerous job safer.',
  },
  {
    years: '2015',
    title: 'Reset and recommit',
    summary:
      'After a difficult year and a period of depression, I rebuilt my technical foundation and chose robotics graduate school in the United States.',
  },
  {
    years: '2016–2018',
    title: 'Colorado School of Mines',
    summary:
      'At the M3 Robotics Lab, I built an MPC-based autonomy stack for GPS-denied navigation and learned how sensing, controls, and software meet on a real robot.',
  },
  {
    years: '2018–2022',
    title: 'DEKA',
    summary:
      'I led part of perception for last-mile robots, from real-time vision models to CUDA kernels and OpenCL/OpenVINO deployment.',
  },
  {
    years: '2022–2026',
    title: 'Zoox',
    summary:
      'I build learned scene representations for autonomous navigation, with a focus on general scene embeddings that support downstream planning.',
  },
] as const;

const journeyHref = '/blog/2025/02/08/my-journey-so-far-full-story.html';
---

<HomeLayout
  title="Home"
  description="Arunabh Mishra is a computer vision researcher and roboticist writing about perception, autonomous systems, machine-learning papers, and implementation."
>
  <section class="home-sky home-sky--integrated" id="top" data-sky-landing>
    <img
      class="home-sky__image"
      src="/assets/images/shootingstar.jpg"
      alt="A shooting star crossing a dark sky above Arunabh in the Tetons"
      width="1778"
      height="1388"
      fetchpriority="high"
    />
    <canvas class="home-sky__reveal" data-sky-reveal aria-hidden="true"></canvas>
    <div class="home-sky__scrim" aria-hidden="true"></div>

    <header class="home-sky__header">
      <a class="home-sky__mark" href="#top" aria-label="Arunabh Mishra, home">AM</a>
      <span>Arunabh Mishra</span>
      <nav class="home-sky-contact" aria-label="Contact me">
        <span>Contact</span>
        <ul>
          {CONTACT_LINKS.map((link) => (
            <li>
              <a href={link.href} aria-label={link.label} title={link.label}>
                <Icon name={link.iconName} />
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <div class="home-sky__copy home-sky__copy--compact">
      <h1>About me</h1>
      <p>
        I&apos;m a computer vision researcher and roboticist at Zoox, where I lead the Perception
        Semantic Reasoning team. We train efficient models that encode driving scenes as part of a
        broader effort to build a generalized scene embedding. Previously, I led a small team
        developing stereo-camera machine-learning models for Roxo, FedEx&apos;s last-mile delivery
        robot. My formal training is in robotics.
      </p>
      <p>
        This blog is where I work through ideas by reading arXiv, writing code, and explaining what
        I learn. The goal behind much of that work is to build safe autonomous systems that work in
        the real world.
      </p>
    </div>

    <section class="home-sky-shelves" id="explore" aria-labelledby="explore-title">
      <h2 id="explore-title">Explore</h2>
      <ol>
        {sectionCards.map((section, index) => (
          <li>
            <a href={section.href}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <b aria-hidden="true">↗</b>
              <strong>{section.title}</strong>
              <small>{section.description}</small>
              <em>{section.count}</em>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="home-sky-timeline" aria-labelledby="journey-title">
      <h2 id="journey-title">
        <a href={journeyHref}>Journey <span aria-hidden="true">↗</span></a>
      </h2>
      <ol>
        {timelineEntries.map((entry) => (
          <li tabindex="0">
            <span>{entry.years}</span>
            <strong>{entry.title}</strong>
            <p>{entry.summary}</p>
          </li>
        ))}
      </ol>
    </section>
  </section>

  <script is:inline>
    (() => {
      const landing = document.querySelector('[data-sky-landing]');
      const canvas = document.querySelector('[data-sky-reveal]');

      if (!(landing instanceof HTMLElement) || !(canvas instanceof HTMLCanvasElement)) {
        return;
      }

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        landing.dataset.skyReady = 'still';
        return;
      }

      const context = canvas.getContext('2d');
      if (!context) {
        return;
      }

      let width = 0;
      let height = 0;
      let density = 1;
      let frame = 0;
      let lastMove = 0;
      const stars = [];

      const resize = () => {
        const bounds = landing.getBoundingClientRect();
        width = Math.max(1, bounds.width);
        height = Math.max(1, bounds.height);
        density = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.round(width * density);
        canvas.height = Math.round(height * density);
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        context.setTransform(density, 0, 0, density, 0, 0);
        context.clearRect(0, 0, width, height);
      };

      const addStars = (clientX, clientY, amount = 4) => {
        const bounds = landing.getBoundingClientRect();
        const originX = clientX - bounds.left;
        const originY = clientY - bounds.top;
        if (originX < 0 || originY < 0 || originX > width || originY > height) {
          return;
        }

        for (let index = 0; index < amount; index += 1) {
          const angle = Math.random() * Math.PI * 2;
          const distance = 8 + Math.random() * 48;
          stars.push({
            x: originX + Math.cos(angle) * distance,
            y: originY + Math.sin(angle) * distance,
            driftX: (Math.random() - 0.5) * 0.08,
            driftY: -0.025 - Math.random() * 0.055,
            size: 0.8 + Math.random() * 2.2,
            life: 0.82 + Math.random() * 0.18,
            decay: 0.007 + Math.random() * 0.006,
            cross: Math.random() > 0.68,
            phase: Math.random() * Math.PI * 2,
          });
        }

        if (!frame) {
          frame = window.requestAnimationFrame(draw);
        }
      };

      const draw = () => {
        context.clearRect(0, 0, width, height);

        for (let index = stars.length - 1; index >= 0; index -= 1) {
          const star = stars[index];
          star.life -= star.decay;
          if (star.life <= 0) {
            stars.splice(index, 1);
            continue;
          }

          star.x += star.driftX;
          star.y += star.driftY;
          const twinkle = 0.72 + Math.sin(star.life * 18 + star.phase) * 0.22;
          const alpha = Math.min(1, star.life * 1.5) * twinkle;

          context.save();
          context.globalAlpha = alpha;
          context.fillStyle = '#fffdf4';
          context.shadowColor = 'rgba(255, 253, 244, 0.92)';
          context.shadowBlur = star.size * 5;
          context.beginPath();
          context.arc(star.x, star.y, star.size, 0, Math.PI * 2);
          context.fill();

          if (star.cross && star.life > 0.36) {
            context.shadowBlur = star.size * 3;
            context.fillRect(star.x - star.size * 3, star.y - 0.35, star.size * 6, 0.7);
            context.fillRect(star.x - 0.35, star.y - star.size * 3, 0.7, star.size * 6);
          }
          context.restore();
        }

        if (stars.length) {
          frame = window.requestAnimationFrame(draw);
        } else {
          frame = 0;
        }
      };

      landing.addEventListener(
        'pointermove',
        (event) => {
          const now = window.performance.now();
          if (now - lastMove < 42) {
            return;
          }
          lastMove = now;
          addStars(event.clientX, event.clientY, 3);
        },
        { passive: true },
      );

      landing.addEventListener('pointerdown', (event) => addStars(event.clientX, event.clientY, 14), {
        passive: true,
      });

      resize();
      landing.dataset.skyReady = 'true';
      new ResizeObserver(resize).observe(landing);
    })();
  </script>
</HomeLayout>
