---
import HomeLayout from '../layouts/HomeLayout.astro';
import { getPostsBySection } from '../lib/content';
import { CODE_PRACTICE_SECTION_SUMMARY, codePracticeProblems } from '../lib/code-practice';
import { READING_LIST_ITEMS } from '../lib/reading-list';

const paperPosts = await getPostsBySection('paper-shorts', 'desc');
const revisionPosts = (await getPostsBySection('revision-notes', 'desc')).filter(
  (post) => post.data.postSlug !== 'cs336-revision-notes',
);
const blogPosts = await getPostsBySection('blog', 'desc');
const buildIntuitionPosts = await getPostsBySection('build-intuition', 'desc');

const totalEntries =
  paperPosts.length +
  blogPosts.length +
  buildIntuitionPosts.length +
  revisionPosts.length +
  READING_LIST_ITEMS.length +
  codePracticeProblems.length;

const sectionCards = [
  {
    id: 'arxiv-notes',
    href: '/paper_summaries_field.html',
    command: 'arxiv-notes',
    title: 'Arxiv Notes',
    description: 'Paper notes that track the contribution, tradeoff, and lasting idea.',
    count: paperPosts.length,
  },
  {
    id: 'blog',
    href: '/blog.html',
    command: 'blog',
    title: 'Blog',
    description: 'Essays on research practice, local models, robotics, and career lessons.',
    count: blogPosts.length,
  },
  {
    id: 'build-intuition',
    href: '/build_intuition.html',
    command: 'build-intuition',
    title: 'Build Intuition',
    description: 'Concept-first walkthroughs for mechanisms that reward slow understanding.',
    count: buildIntuitionPosts.length,
  },
  {
    id: 'revision-notes',
    href: '/revision_notes.html',
    command: 'revision-notes',
    title: 'Revision Notes',
    description: 'Course notes and implementation details kept for later review.',
    count: revisionPosts.length,
  },
  {
    id: 'reading-list',
    href: '/reading_list.html',
    command: 'reading-list',
    title: 'Reading List',
    description: 'External writing worth returning to, with one reason to read each link.',
    count: READING_LIST_ITEMS.length,
  },
  {
    id: 'code',
    href: '/code.html',
    command: 'code',
    title: 'Code',
    description: CODE_PRACTICE_SECTION_SUMMARY,
    count: codePracticeProblems.length,
  },
] as const;

const recentShelves = [
  {
    title: 'Arxiv Notes',
    href: '/paper_summaries_field.html',
    summary: 'Paper notes that track the contribution, tradeoff, and lasting idea.',
    posts: paperPosts.slice(0, 2),
    emptyMessage: 'No paper notes yet.',
  },
  {
    title: 'Blog',
    href: '/blog.html',
    summary: 'Essays on research practice, local models, robotics, and career lessons.',
    posts: blogPosts.slice(0, 2),
    emptyMessage: 'No essays yet.',
  },
  {
    title: 'Build Intuition',
    href: '/build_intuition.html',
    summary: 'Concept-first walkthroughs for mechanisms that reward slow understanding.',
    posts: buildIntuitionPosts.slice(0, 2),
    emptyMessage: 'No explainers yet.',
  },
  {
    title: 'Revision Notes',
    href: '/revision_notes.html',
    summary: 'Course notes and implementation details kept for later review.',
    posts: revisionPosts.slice(0, 2),
    emptyMessage: 'No revision notes yet.',
  },
] as const;

const timelineEntries = [
  {
    years: '2010 - 2014',
    title: 'MIT, Manipal',
    summary:
      'I studied Mechatronics Engineering at MIT, Manipal, where hands-on projects made robotics feel real. For my thesis, my team built an areca-nut harvesting robot that climbed tall trees and aimed to make a dangerous job safer for farmers.',
  },
  {
    years: '2015',
    title: 'Reset And Recommit',
    summary:
      'A difficult year became a turning point. After setbacks and a period of depression, I found a clearer sense of purpose, rebuilt my technical foundation, and decided to pursue robotics graduate school in the United States.',
  },
  {
    years: '2016 - 2018',
    title: 'Colorado School Of Mines',
    summary:
      'I completed a graduate degree in Mechanical Engineering with a robotics specialization at the Colorado School of Mines. At the M3 Robotics Lab, I worked on GPS-denied navigation, built an MPC-based autonomy stack, and learned how sensors, controls, and software come together on real robots.',
  },
  {
    years: '2018 - 2022',
    title: 'DEKA',
    summary:
      'At DEKA, I led part of the perception stack for last-mile autonomous robots. The work ranged from training real-time computer vision models to writing CUDA kernels and porting major parts of the stack to OpenCL and OpenVINO.',
  },
  {
    years: '2022 - 2026',
    title: 'Zoox',
    summary:
      'At Zoox, I focus on computer vision research for autonomous navigation, building learned representations that encode scene semantics and support downstream planning. I currently lead work on a generalized scene embedding designed to scale across diverse driving contexts.',
  },
] as const;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    month: 'short',
    day: '2-digit',
    year: 'numeric',
  });
---

<HomeLayout title="Home" timelineEntries={timelineEntries}>
  <section class="home-hero" id="top">
    <div class="home-hero__content">
      <div class="home-hero__copy">
        <h1 class="home-title">ARUNABH.BLOG</h1>
        <p class="lead">
          I work on computer vision and robotics for autonomous systems. This site is where I keep
          the research notes, implementation records, and personal essays I expect to reuse.
        </p>
        <nav class="home-command-bar home-command-bar--hero" aria-label="Homepage sections">
          <a href="#about">/about</a>
          <a href="#latest">/latest</a>
          <a href="/reading_list.html">/reading</a>
          <a href="/code.html">/code</a>
        </nav>
      </div>

      <dl class="home-stat-list" aria-label="Site overview">
        <div>
          <dt>Sections</dt>
          <dd>{String(sectionCards.length).padStart(2, '0')}</dd>
        </div>
        <div>
          <dt>Entries</dt>
          <dd>{totalEntries}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="home-story-grid" id="about">
    <article class="home-panel home-panel--story" aria-labelledby="about-title">
      <div class="home-panel__heading">
        <h2 id="about-title">About me</h2>
      </div>
      <p class="intro-text">
        I work in computer vision research at Zoox, where I build learned representations for
        autonomous driving scenes. Before that, I led parts of the perception stack at DEKA for
        Roxo, FedEx&apos;s last-mile delivery robot, focused on short-range perception and
        traffic-light understanding.
      </p>

      <p class="intro-text">
        Robotics started as undergraduate project work at MIT, Manipal, then became a deliberate
        commitment to autonomy during graduate school at the Colorado School of Mines.
      </p>

      <p class="intro-text">
        The throughline is systems that make the physical world safer and easier to navigate. The
        site is a working archive for that throughline.
      </p>
    </article>

    <article class="home-panel home-panel--map" id="sections" aria-labelledby="sections-title">
      <div class="home-panel__heading">
        <h2 id="sections-title">Writing and notes</h2>
      </div>
      <ul class="home-section-map">
        {sectionCards.map((section) => (
          <li>
            <a href={section.href}>
              <span>
                <strong>{section.title}</strong>
                <small>{section.description}</small>
              </span>
              <em>{section.count}</em>
            </a>
          </li>
        ))}
      </ul>
    </article>
  </section>

  <section class="home-shelves" id="latest">
    <div class="home-section-heading">
      <h2>Latest writing</h2>
      <p>
        The newest hand-written entries across the site, grouped by the kind of work they do.
      </p>
    </div>

    <div class="home-shelf-grid">
      {recentShelves.map((shelf) => (
        <article class="home-panel home-panel--shelf">
          <div class="home-shelf__header">
            <div class="home-shelf__title-block">
              <h3>{shelf.title}</h3>
              <p>{shelf.summary}</p>
            </div>
            <a href={shelf.href}>View all</a>
          </div>

          {shelf.posts.length > 0 ? (
            <ul class="home-post-list">
              {shelf.posts.map((post) => (
                <li>
                  <a href={post.data.legacyPath}>{post.data.title}</a>
                  <small>{formatDate(post.data.date)}</small>
                </li>
              ))}
            </ul>
          ) : (
            <p class="home-empty-state">{shelf.emptyMessage}</p>
          )}
        </article>
      ))}
    </div>
  </section>

</HomeLayout>
